{
  "name": "finance-close-calendar",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:pages": "tsc --noEmit && VITE_BASE_PATH=/finance-close-calendar/ vite build",
    "build:portable": "tsc --noEmit && VITE_BASE_PATH=./ VITE_PORTABLE_MODE=1 vite build --outDir portable/app",
    "package:portable": "npm run build:portable && node scripts/create-portable-package.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  }
}
